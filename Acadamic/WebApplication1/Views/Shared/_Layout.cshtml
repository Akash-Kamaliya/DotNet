<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MOM Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <nav class="sidebar bg-dark text-white">
            <div class="p-3 border-bottom">
                <h5 class="mb-0"><i class="bi bi-file-text"></i> MOM Portal</h5>
            </div>
            <ul class="nav flex-column p-2">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Meetings" asp-action="Index">
                        <i class="bi bi-people"></i> Meetings
                    </a>
                </li>

                <!-- Admin Only Links -->
                @if (Context.Session.GetString("user") != null)
                {
                    var userJson = Context.Session.GetString("user");
                    var user = System.Text.Json.JsonSerializer.Deserialize<dynamic>(userJson);
                    var isAdmin = false; // Check role from user object
                    
                    @if (isAdmin)
                    {
                        <hr class="bg-secondary" />
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Staff" asp-action="Index">
                                <i class="bi bi-person-badge"></i> Staff Management
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Roles" asp-action="Index">
                                <i class="bi bi-shield-lock"></i> Roles
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Departments" asp-action="Index">
                                <i class="bi bi-building"></i> Departments
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Venues" asp-action="Index">
                                <i class="bi bi-geo-alt"></i> Venues
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="MeetingTypes" asp-action="Index">
                                <i class="bi bi-list-ul"></i> Meeting Types
                            </a>
                        </li>
                    }
                }
            </ul>

            <!-- Logout -->
            <div class="mt-auto p-2 border-top">
                @if (Context.Session.GetString("user") != null)
                {
                    <form method="post" asp-controller="Account" asp-action="Logout">
                        <button type="submit" class="btn btn-danger btn-sm w-100">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                }
            </div>
        </nav>

        <!-- Main Content -->
        <main class="flex-grow-1">
            <div class="container-fluid p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>