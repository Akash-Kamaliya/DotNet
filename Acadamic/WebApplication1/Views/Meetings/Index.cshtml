@model MeetingListViewModel

@{
    ViewData["Title"] = "Meetings";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h1 class="h2 mb-1">Meetings</h1>
        <p class="text-muted">Manage all meetings</p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Meeting
    </a>
</div>

<div class="card">
    <div class="card-body">
        @if (Model?.Meetings?.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Meeting #</th>
                            <th>Date</th>
                            <th>Venue</th>
                            <th>Type</th>
                            <th>Department</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var meeting in Model.Meetings)
                        {
                            <tr>
                                <td>@meeting.MeetingTitle</td>
                                <td>@meeting.MeetingNumber</td>
                                <td>@meeting.MeetingDate.ToString("dd MMM yyyy")</td>
                                <td>@meeting.MeetingVenueName</td>
                                <td>@meeting.MeetingTypeName</td>
                                <td>@meeting.DepartmentName</td>
                                <td>
                                    <a href="@Url.Action("Edit", new { id = meeting.MeetingID })" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <form method="post" action="@Url.Action("Delete", new { id = meeting.MeetingID })" style="display: inline;">
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-center text-muted py-3">No meetings found</p>
        }
    </div>
</div>